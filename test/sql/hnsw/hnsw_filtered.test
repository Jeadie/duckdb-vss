# name: test/sql/hnsw/hnsw_filtered.test
# description: Filtered HNSW - WHERE clause filters pushed into index scan via bitmap pre-filter
# group: [hnsw]

require vss

# ───────────────────────────────────────────────────────────────────────────────
# Setup: 100 rows with a deterministic label column and 1D-like vectors so that
# distance ordering is predictable.  Rows with even id get label='A', odd id get
# label='B'.  Vectors are along the x-axis so array_distance([0.5,0,0]) always
# gives |i*0.01 - 0.5|, and the k-nearest are those with i closest to 50.
# ───────────────────────────────────────────────────────────────────────────────

statement ok
CREATE TABLE flt (
    id    INTEGER,
    label VARCHAR,
    vec   FLOAT[3]
);

statement ok
INSERT INTO flt
SELECT
    i,
    CASE WHEN i % 2 = 0 THEN 'A' ELSE 'B' END,
    array_value((i * 0.01)::FLOAT, 0.0::FLOAT, 0.0::FLOAT)
FROM range(100) t(i);

statement ok
CREATE INDEX flt_idx ON flt USING HNSW (vec);

# Use high ef_search so results are near-exact on this tiny table
statement ok
SET hnsw_ef_search = 200;

# ───────────────────────────────────────────────────────────────────────────────
# 1. No filter — baseline regression: index scan still works
# ───────────────────────────────────────────────────────────────────────────────

query II
EXPLAIN SELECT id FROM flt ORDER BY array_distance(vec, [0.5, 0.0, 0.0]::FLOAT[3]) LIMIT 5;
----
physical_plan	<REGEX>:.*HNSW_INDEX_SCAN.*

query I
SELECT count(*) FROM (
    SELECT id FROM flt ORDER BY array_distance(vec, [0.5, 0.0, 0.0]::FLOAT[3]) LIMIT 5
);
----
5

# ───────────────────────────────────────────────────────────────────────────────
# 2. Plan shape: WITH filter pushdown enabled the LogicalFilter is NOT present
#    above the HNSW_INDEX_SCAN (filters are consumed into the scan's bind data).
# ───────────────────────────────────────────────────────────────────────────────

statement ok
SET hnsw_enable_filter_pushdown = true;

query II
EXPLAIN SELECT id FROM flt WHERE label = 'A' ORDER BY array_distance(vec, [0.5, 0.0, 0.0]::FLOAT[3]) LIMIT 5;
----
physical_plan	<REGEX>:.*HNSW_INDEX_SCAN.*

# ───────────────────────────────────────────────────────────────────────────────
# 3. Equality filter — must return exactly 5 rows, all with label='A'
#    (50 rows satisfy the filter, so there are enough to fill the limit)
# ───────────────────────────────────────────────────────────────────────────────

query I
SELECT count(*) FROM (
    SELECT id FROM flt WHERE label = 'A'
    ORDER BY array_distance(vec, [0.5, 0.0, 0.0]::FLOAT[3]) LIMIT 5
);
----
5

# Verify all returned rows actually satisfy the filter
query I
SELECT count(*) FROM (
    SELECT id, label FROM flt WHERE label = 'A'
    ORDER BY array_distance(vec, [0.5, 0.0, 0.0]::FLOAT[3]) LIMIT 5
) WHERE label != 'A';
----
0

# ───────────────────────────────────────────────────────────────────────────────
# 4. Range filter — same guarantee with id >= 50 (also 50 valid rows)
# ───────────────────────────────────────────────────────────────────────────────

query I
SELECT count(*) FROM (
    SELECT id FROM flt WHERE id >= 50
    ORDER BY array_distance(vec, [0.5, 0.0, 0.0]::FLOAT[3]) LIMIT 5
);
----
5

query I
SELECT count(*) FROM (
    SELECT id FROM flt WHERE id >= 50
    ORDER BY array_distance(vec, [0.5, 0.0, 0.0]::FLOAT[3]) LIMIT 5
) WHERE id < 50;
----
0

# ───────────────────────────────────────────────────────────────────────────────
# 5. IS NOT NULL filter — all 100 rows qualify, must return exactly 5
# ───────────────────────────────────────────────────────────────────────────────

query I
SELECT count(*) FROM (
    SELECT id FROM flt WHERE label IS NOT NULL
    ORDER BY array_distance(vec, [0.5, 0.0, 0.0]::FLOAT[3]) LIMIT 5
);
----
5

# ───────────────────────────────────────────────────────────────────────────────
# 6. Highly selective filter: only 3 rows match LIMIT=10 → return exactly 3
# ───────────────────────────────────────────────────────────────────────────────

query I
SELECT count(*) FROM (
    SELECT id FROM flt WHERE id IN (10, 50, 90)
    ORDER BY array_distance(vec, [0.5, 0.0, 0.0]::FLOAT[3]) LIMIT 10
);
----
3

# Verify the 3 returned are exactly {10, 50, 90}
query I
SELECT id FROM (
    SELECT id FROM flt WHERE id IN (10, 50, 90)
    ORDER BY array_distance(vec, [0.5, 0.0, 0.0]::FLOAT[3]) LIMIT 10
) ORDER BY id;
----
10
50
90

# ───────────────────────────────────────────────────────────────────────────────
# 7. Escape hatch: SET hnsw_enable_filter_pushdown = false reverts to the old
#    post-filter behavior (plan has a Filter node above the index scan).
# ───────────────────────────────────────────────────────────────────────────────

statement ok
SET hnsw_enable_filter_pushdown = false;

query II
EXPLAIN SELECT id FROM flt WHERE label = 'A'
ORDER BY array_distance(vec, [0.5, 0.0, 0.0]::FLOAT[3]) LIMIT 5;
----
physical_plan	<REGEX>:.*FILTER.*

# Re-enable for subsequent tests
statement ok
SET hnsw_enable_filter_pushdown = true;

# ───────────────────────────────────────────────────────────────────────────────
# 8. Correctness without index: seq_scan result must match HNSW result for the
#    selective filter (id IN ...) so we can verify the HNSW result is correct.
# ───────────────────────────────────────────────────────────────────────────────

query I
SELECT id FROM flt WHERE id IN (10, 50, 90)
ORDER BY array_distance(vec, [0.5, 0.0, 0.0]::FLOAT[3]);
----
50
90
10

# ───────────────────────────────────────────────────────────────────────────────
# 9. Computed-only predicate: lower(label) = 'a'
#    DuckDB does NOT push this into table_filters; it stays as a LogicalFilter node.
#    The HNSW optimizer must detect and push it via pushed_filter_expressions.
# ───────────────────────────────────────────────────────────────────────────────

statement ok
SET hnsw_enable_filter_pushdown = true;

# Plan shape: HNSW_INDEX_SCAN with no FILTER node above it (LogicalFilter consumed)
query II
EXPLAIN SELECT id FROM flt WHERE lower(label) = 'a'
ORDER BY array_distance(vec, [0.5, 0.0, 0.0]::FLOAT[3]) LIMIT 5;
----
physical_plan	<REGEX>:.*HNSW_INDEX_SCAN.*

# Returns exactly LIMIT rows — bitmap pre-filter prevents underfill
query I
SELECT count(*) FROM (
    SELECT id FROM flt WHERE lower(label) = 'a'
    ORDER BY array_distance(vec, [0.5, 0.0, 0.0]::FLOAT[3]) LIMIT 5
);
----
5

# All returned rows satisfy the predicate (no wrong results)
query I
SELECT count(*) FROM (
    SELECT id, label FROM flt WHERE lower(label) = 'a'
    ORDER BY array_distance(vec, [0.5, 0.0, 0.0]::FLOAT[3]) LIMIT 5
) WHERE lower(label) != 'a';
----
0

# ───────────────────────────────────────────────────────────────────────────────
# 10. Mixed: table_filter (id >= 50) AND computed predicate (lower(label) = 'a')
#     Both filters are pushed: table_filter into pushed_filters (zone-map pruning),
#     computed predicate into pushed_filter_expressions.
# ───────────────────────────────────────────────────────────────────────────────

query I
SELECT count(*) FROM (
    SELECT id, label FROM flt
    WHERE id >= 50 AND lower(label) = 'a'
    ORDER BY array_distance(vec, [0.5, 0.0, 0.0]::FLOAT[3]) LIMIT 5
);
----
5

# No rows with id < 50 or wrong label
query I
SELECT count(*) FROM (
    SELECT id, label FROM flt
    WHERE id >= 50 AND lower(label) = 'a'
    ORDER BY array_distance(vec, [0.5, 0.0, 0.0]::FLOAT[3]) LIMIT 5
) WHERE id < 50 OR lower(label) != 'a';
----
0

# ───────────────────────────────────────────────────────────────────────────────
# 11. Escape hatch with a computed predicate:
#     SET hnsw_enable_filter_pushdown = false must still produce a FILTER node.
# ───────────────────────────────────────────────────────────────────────────────

statement ok
SET hnsw_enable_filter_pushdown = false;

query II
EXPLAIN SELECT id FROM flt WHERE lower(label) = 'a'
ORDER BY array_distance(vec, [0.5, 0.0, 0.0]::FLOAT[3]) LIMIT 5;
----
physical_plan	<REGEX>:.*FILTER.*

statement ok
SET hnsw_enable_filter_pushdown = true;
